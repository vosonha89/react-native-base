{
  "name": "react-native-base",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 50 --ignore-pattern \"framework/**\" --ignore-pattern \"*.js\"",
    "start": "npm run lint && react-native start --reset-cache",
    "regenerate-platform": "npx react-native eject",
    "start:android": "concurrently --kill-others-on-fail \"npm start\" \"npm run android\"",
    "start:ios": "concurrently --kill-others-on-fail \"npm start\" \"npm run ios\"",
    "start:debug": "npm run lint && npx react-native start --reset-cache",
    "build:prepare": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/",
    "android:build-debug": "npm run build:prepare && cd android && ./gradlew assembleDebug",
    "android:permit": "cd android && chmod +x ./gradlew",
    "android:installdebug": "npm run build:debug && cd android && adb install app/build/outputs/apk/debug/app-debug.apk",
    "devtools": "react-devtools",
    "link": "npx react-native-asset",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/native": "7.3.7",
    "@react-navigation/native-stack": "7.17.9",
    "one-frontend-framework": "^0.0.6",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/plugin-proposal-decorators": "^7.24.1",
    "@babel/plugin-transform-class-properties": "^7.24.1",
    "@babel/plugin-transform-class-static-block": "^7.24.4",
    "@babel/preset-env": "^7.26.9",
    "@babel/runtime": "^7.26.10",
    "@eslint/js": "^9.24.0",
    "@react-native-community/cli": "20.2.0",
    "@react-native-community/cli-platform-android": "20.2.0",
    "@react-native-community/cli-platform-ios": "20.2.0",
    "@react-native-community/template": "^0.86.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.14",
    "@types/react": "19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.4",
    "react-native-eject": "^1.0.2",
    "react-test-renderer": "19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "@react-native/eslint-config": {
      "eslint-plugin-ft-flow": "^3.0.0"
    }
  },
  "engines": {
    "node": "^20.19.4 || ^22.13.0 || ^24.3.0 || >= 25.0.0"
  }
}
